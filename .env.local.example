# Copie para .env.local (nunca commitado) e preencha os valores reais.
# Só infraestrutura do Supabase aqui — nenhum segredo de negócio (token Meta,
# credencial Google) fica em env: esses vivem cifrados no Supabase Vault
# (ver Fase 0.5) e são lidos só no servidor.

# Supabase (criado na Fase 0.5)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Segredo compartilhado que a rota /api/cron/process-meta-jobs valida antes de
# processar a fila de sync da Meta (chamada via pg_cron/pg_net, ver Fase 2)
CRON_SECRET=
